rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper: check if the user is an admin
    function isAdmin() {
      return request.auth != null
        && request.auth.uid != null
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // Helper: check if the user is authenticated
    function isAuthenticated() {
      return request.auth != null && request.auth.uid != null;
    }

    // Users collection: admin can write, owner can read their own, admin can read all
    match /users/{userId} {
      allow read: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
      allow create: if isAuthenticated() && request.auth.uid == userId;
      allow update, delete: if isAuthenticated() && request.auth.uid == userId;
    }

    // Categories collection
    match /categories/{categoryId} {
      // Any authenticated user can read categories
      allow read: if isAuthenticated();
      // Only admin can create, update, delete
      allow create: if isAdmin();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // Products collection (basic rules for now)
    match /products/{productId} {
      allow read: if isAuthenticated();
      allow create: if isAdmin();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // Orders collection (POS sales + sales generated from delivered pedidos)
    match /orders/{orderId} {
      allow read: if isAuthenticated();
      allow create: if isAdmin();
      allow update: if isAdmin();
      allow delete: if false;
    }

    // Pedidos collection (orders with multi-state lifecycle and stock reservation)
    match /pedidos/{pedidoId} {
      allow read: if isAuthenticated();
      allow create: if isAdmin();
      allow update: if isAdmin();
      allow delete: if false;
    }

    // Deny everything else
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
